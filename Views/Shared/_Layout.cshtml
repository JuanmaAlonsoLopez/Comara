<!DOCTYPE html>
<html lang="es" translate="no">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - comara</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/comara.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/Images/logos/2.png" alt="Logo COMARA" style="height: 40px; margin-right: 10px;" />
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Clientes" ? "active fw-bold" : "text-dark")" asp-area="" asp-controller="Clientes" asp-action="Index">Clientes</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Ventas" ? "active fw-bold" : "text-dark")" asp-area="" asp-controller="Ventas" asp-action="Index">Ventas</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Facturas" ? "active fw-bold" : "text-dark")" asp-area="" asp-controller="Facturas" asp-action="Index">Facturas</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Caja" ? "active fw-bold" : "text-dark")" asp-area="" asp-controller="Caja" asp-action="Index">Caja</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Cotizaciones" ? "active fw-bold" : "text-dark")" asp-area="" asp-controller="Cotizaciones" asp-action="Index">Cotizaciones</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Stock" ? "active fw-bold" : "text-dark")" asp-area="" asp-controller="Stock" asp-action="Index">Stock</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-with-notification @(currentController == "Reportes" ? "active fw-bold" : "text-dark")" asp-area="" asp-controller="Reportes" asp-action="Index">
                                    Reportes
                                    @await Component.InvokeAsync("StockCriticoNotification")
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Listas" ? "active fw-bold" : "text-dark")" asp-area="" asp-controller="Listas" asp-action="Index">Listas</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Articulos" ? "active fw-bold" : "text-dark")" asp-area="" asp-controller="Articulos" asp-action="Index">Articulos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Proveedores" ? "active fw-bold" : "text-dark")" asp-area="" asp-controller="Proveedores" asp-action="Index">Proveedores</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Marcas" ? "active fw-bold" : "text-dark")" asp-area="" asp-controller="Marcas" asp-action="Index">Marcas</a>
                            </li>
                        </ul>
                    }
                    else
                    {
                        <ul class="navbar-nav flex-grow-1"></ul>
                    }
                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle"></i> @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <li>
                                        <span class="dropdown-item-text">
                                            <small class="text-muted">@User.FindFirst("FullName")?.Value</small>
                                        </span>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword">
                                            <i class="bi bi-key"></i> Cambiar Contraseña
                                        </a>
                                    </li>
                                    @if (User.FindFirst("Role")?.Value == "admin")
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Usuarios" asp-action="Index">
                                                <i class="bi bi-people"></i> Gestión de Usuarios
                                            </a>
                                        </li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item">
                                                <i class="bi bi-box-arrow-right"></i> Cerrar Sesión
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-primary" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right"></i> Iniciar Sesión
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container d-flex justify-content-between align-items-center">
            <span>&copy; 2025 - comara</span>
            <div>
                <a href="/manual-usuario.html" target="_blank" class="text-muted me-3" title="Ver Manual de Usuario">
                    <i class="bi bi-book"></i> Manual de Usuario
                </a>
                <a href="/manual-usuario.html" download="Manual_Usuario_COMARA.html" class="text-muted" title="Descargar Manual">
                    <i class="bi bi-download"></i> Descargar Manual
                </a>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
