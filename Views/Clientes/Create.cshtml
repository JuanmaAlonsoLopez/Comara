@model comara.Models.Cliente

@{
    ViewData["Title"] = "Crear Cliente";
}

<h1>Crear</h1>

<h4>Cliente</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <h5 class="text-primary">Datos Generales</h5>
            <div class="form-group">
                <label asp-for="CliNombre" class="control-label"></label>
                <input asp-for="CliNombre" class="form-control" />
                <span asp-validation-for="CliNombre" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CliDireccion" class="control-label"></label>
                <input asp-for="CliDireccion" class="form-control" />
                <span asp-validation-for="CliDireccion" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CliTelefono" class="control-label"></label>
                <input asp-for="CliTelefono" class="form-control" />
                <span asp-validation-for="CliTelefono" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CliEmail" class="control-label"></label>
                <input asp-for="CliEmail" class="form-control" type="email" />
                <span asp-validation-for="CliEmail" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="control-label">Forma de Pago *</label>
                <select asp-for="CliFormaPago" class="form-control" required>
                    <option value="">-- Seleccionar --</option>
                    <option value="1">Cuenta Corriente</option>
                    <option value="2">Efectivo</option>
                    <option value="3">Ambos</option>
                </select>
                <span asp-validation-for="CliFormaPago" class="text-danger"></span>
                <small class="form-text text-muted">Tipo de pago que acepta el cliente</small>
            </div>

            <hr />
            <h5 class="text-primary">Datos para Facturación Electrónica AFIP</h5>
            <small class="text-muted">Requeridos para generar facturas electrónicas</small>

            <div class="form-group mt-3">
                <label class="control-label">Tipo de Documento *</label>
                <select asp-for="CliTipoDoc" class="form-control" required>
                    <option value="">-- Seleccionar --</option>
                    <option value="1">CUIT (80)</option>
                    <option value="2">CUIL (86)</option>
                    <option value="3">DNI (96)</option>
                    <option value="4">Pasaporte (94)</option>
                    <option value="5">Consumidor Final (99)</option>
                </select>
                <span asp-validation-for="CliTipoDoc" class="text-danger"></span>
                <small class="form-text text-muted">Tipo de documento según AFIP</small>
            </div>

            <div class="form-group">
                <label class="control-label">Número de Documento *</label>
                <input asp-for="CliNumDoc" class="form-control" required maxlength="20" placeholder="Ej: 20123456789" />
                <span asp-validation-for="CliNumDoc" class="text-danger"></span>
                <small class="form-text text-muted">CUIT/DNI/Otro sin guiones (solo números)</small>
            </div>

            <div class="form-group">
                <label class="control-label">Condición ante IVA *</label>
                <select asp-for="CliCondicionIVA" class="form-control" required>
                    <option value="">-- Seleccionar --</option>
                    <option value="1">IVA Responsable Inscripto</option>
                    <option value="4">IVA Sujeto Exento</option>
                    <option value="5">Consumidor Final</option>
                    <option value="6">Responsable Monotributo</option>
                    <option value="7">Sujeto No Categorizado</option>
                </select>
                <span asp-validation-for="CliCondicionIVA" class="text-danger"></span>
                <small class="form-text text-muted">Condición frente al IVA</small>
            </div>

            <div class="alert alert-info">
                <small>
                    <strong>Guía:</strong><br />
                    - <strong>Factura A:</strong> Responsable Inscripto<br />
                    - <strong>Factura B:</strong> Monotributo o Exento<br />
                    - <strong>Factura C:</strong> Consumidor Final
                </small>
            </div>

            <hr />
            <div class="form-group">
                <input type="submit" value="Crear" class="btn btn-sm btn-primary" />
                <a asp-action="Index" class="btn btn-sm btn-secondary">Volver a la lista</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
