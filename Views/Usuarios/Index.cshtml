@model IEnumerable<comara.Models.Usuario>

@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<h1>Gestión de Usuarios</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Crear Nuevo Usuario</a>
</p>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.UsuUsername)</th>
            <th>@Html.DisplayNameFor(model => model.UsuNombreCompleto)</th>
            <th>@Html.DisplayNameFor(model => model.UsuEmail)</th>
            <th>@Html.DisplayNameFor(model => model.UsuRole)</th>
            <th>@Html.DisplayNameFor(model => model.UsuActivo)</th>
            <th>@Html.DisplayNameFor(model => model.UsuUltimoLogin)</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr class="@(item.UsuActivo ? "" : "table-secondary")">
                <td>@item.UsuUsername</td>
                <td>@item.UsuNombreCompleto</td>
                <td>@(item.UsuEmail ?? "-")</td>
                <td>
                    @if (item.UsuRole == "admin")
                    {
                        <span class="badge bg-danger">Administrador</span>
                    }
                    else
                    {
                        <span class="badge bg-info">Usuario</span>
                    }
                </td>
                <td>
                    @if (item.UsuActivo)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactivo</span>
                    }
                </td>
                <td>@(item.UsuUltimoLogin?.ToString("dd/MM/yyyy HH:mm") ?? "Nunca")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="ResetPassword" asp-route-id="@item.Id" class="btn btn-sm btn-info">Resetear</a>
                    @if (item.UsuActivo)
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Desactivar</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
