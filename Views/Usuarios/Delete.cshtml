@model comara.Models.Usuario

@{
    ViewData["Title"] = "Desactivar Usuario";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h4><i class="bi bi-exclamation-triangle"></i> Desactivar Usuario</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <i class="bi bi-info-circle"></i>
                        <strong>Nota:</strong> Esta acción desactivará el usuario. El usuario no podrá iniciar sesión pero sus datos se conservarán en el sistema.
                    </div>

                    <h5 class="mb-3">¿Está seguro que desea desactivar este usuario?</h5>

                    <dl class="row">
                        <dt class="col-sm-4">Nombre de Usuario</dt>
                        <dd class="col-sm-8"><strong>@Model.UsuUsername</strong></dd>

                        <dt class="col-sm-4">Nombre Completo</dt>
                        <dd class="col-sm-8">@Model.UsuNombreCompleto</dd>

                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">@(Model.UsuEmail ?? "No especificado")</dd>

                        <dt class="col-sm-4">Rol</dt>
                        <dd class="col-sm-8">
                            @if (Model.UsuRole == "admin")
                            {
                                <span class="badge bg-danger">Administrador</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">Usuario</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Estado Actual</dt>
                        <dd class="col-sm-8">
                            @if (Model.UsuActivo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Ya está inactivo</span>
                            }
                        </dd>
                    </dl>

                    @if (!Model.UsuActivo)
                    {
                        <div class="alert alert-info">
                            Este usuario ya está desactivado.
                        </div>
                    }

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-grid gap-2 d-md-flex justify-content-md-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Cancelar
                            </a>
                            @if (Model.UsuActivo)
                            {
                                <button type="submit" class="btn btn-danger">
                                    <i class="bi bi-x-circle"></i> Confirmar Desactivación
                                </button>
                            }
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
