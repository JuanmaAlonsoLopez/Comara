@model comara.Models.Cotizacion

@{
    ViewData["Title"] = "Detalles de Cotizacion";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h2><i class="bi bi-file-text"></i> Detalles de la Cotizacion</h2>
        </div>
    </div>

    <div class="row">
        <!-- Informacion de la Cotizacion -->
        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-info-circle"></i> Informacion General</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Codigo:</dt>
                        <dd class="col-sm-8"><strong>#@Model.CotCod</strong></dd>

                        <dt class="col-sm-4">Fecha:</dt>
                        <dd class="col-sm-8">@Model.CotFech.ToString("dd/MM/yyyy")</dd>

                        <dt class="col-sm-4">Cliente:</dt>
                        <dd class="col-sm-8">@(Model.Cliente?.CliNombre ?? "Sin especificar")</dd>

                        <dt class="col-sm-4">Estado:</dt>
                        <dd class="col-sm-8">
                            @{
                                var estadoDescripcion = Model.Estado?.Descripcion ?? "Pendiente";
                                var estadoColor = Model.Estado?.Color ?? "info";
                                var badgeClass = estadoColor == "warning" ? $"bg-{estadoColor} text-dark" : $"bg-{estadoColor}";
                            }
                            <span class="badge @badgeClass">@estadoDescripcion</span>
                        </dd>

                        <dt class="col-sm-4">Total:</dt>
                        <dd class="col-sm-8">
                            <span class="fs-4 text-success fw-bold">$@string.Format("{0:N2}", Model.CotTotal)</span>
                        </dd>

                        <dt class="col-sm-4">Razon:</dt>
                        <dd class="col-sm-8">@(Model.RazonCrea?.NombreRazon ?? "-")</dd>

                        <dt class="col-sm-4">Mantenimiento de Oferta:</dt>
                        <dd class="col-sm-8">@((Model.CotDiasOferta.HasValue) ? Model.CotDiasOferta.Value.ToString() : "-") días</dd>

                        <dt class="col-sm-4">Pago:</dt>
                        <dd class="col-sm-8">@((Model.CotDiasPago.HasValue) ? Model.CotDiasPago.Value.ToString() : "-") Dias F/F</dd>
                    </dl>
                </div>
            </div>
        </div>

        <!-- Informacion del Cliente -->
        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-person"></i> Datos del Cliente</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Nombre:</dt>
                        <dd class="col-sm-8">@(Model.Cliente?.CliNombre ?? "No especificado")</dd>

                        <dt class="col-sm-4">Documento:</dt>
                        <dd class="col-sm-8">@(Model.Cliente?.CliNumDoc ?? "No especificado")</dd>

                        <dt class="col-sm-4">Telefono:</dt>
                        <dd class="col-sm-8">@(Model.Cliente?.CliTelefono ?? "No especificado")</dd>

                        <dt class="col-sm-4">Email:</dt>
                        <dd class="col-sm-8">@(Model.Cliente?.CliEmail ?? "No especificado")</dd>

                        <dt class="col-sm-4">Direccion:</dt>
                        <dd class="col-sm-8">@(Model.Cliente?.CliDireccion ?? "No especificada")</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    <!-- Detalle de Articulos -->
    <div class="row">
        <div class="col-12">
            <div class="card mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="bi bi-list-ul"></i> Articulos de la Cotizacion</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Codigo</th>
                                <th>Descripcion</th>
                                <th class="text-center">Cantidad</th>
                                <th class="text-end">Precio Unit.</th>
                                <th class="text-end">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.DetalleCotizaciones != null && Model.DetalleCotizaciones.Any())
                            {
                                @foreach (var detalle in Model.DetalleCotizaciones)
                                {
                                    <tr>
                                        <td>@detalle.Articulo?.ArtCod</td>
                                        <td>@detalle.Articulo?.ArtDesc</td>
                                        <td class="text-center">@detalle.DetCant</td>
                                        <td class="text-end">$@string.Format("{0:N2}", detalle.DetPrecio)</td>
                                        <td class="text-end"><strong>$@string.Format("{0:N2}", detalle.DetSubtotal)</strong></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted">No hay articulos en esta cotizacion</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="4" class="text-end"><strong>TOTAL:</strong></td>
                                <td class="text-end"><strong class="fs-5 text-success">$@string.Format("{0:N2}", Model.CotTotal)</strong></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Mensajes de error/exito (Fix #7: ahora Details muestra TempData) -->
    @if (TempData["Error"] != null)
    {
        <div class="row mb-3">
            <div class="col-12">
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="row mb-3">
            <div class="col-12">
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        </div>
    }

    <!-- Botones de Accion -->
    <div class="row">
        <div class="col-12">
            <div class="d-flex flex-wrap gap-2">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Volver a la Lista
                </a>

                @{
                    // Fix #5: usar CotEstadoId (FK) en lugar del string legacy
                    var esEditable = Model.CotEstadoId != CotizacionEstadoConstantes.Convertida;
                }
                @if (esEditable)
                {
                    <a asp-action="Edit" asp-route-id="@Model.CotCod" class="btn btn-warning">
                        <i class="bi bi-pencil"></i> Editar
                    </a>

                    <a asp-action="ConvertToSale" asp-route-id="@Model.CotCod" class="btn btn-success">
                        <i class="bi bi-cart-check"></i> Convertir a Venta
                    </a>
                }

                <a asp-action="DescargarPresupuestoPDF" asp-route-id="@Model.CotCod" class="btn btn-danger">
                    <i class="bi bi-file-earmark-pdf"></i> Descargar PDF
                </a>

                @if (esEditable)
                {
                    <a asp-action="Delete" asp-route-id="@Model.CotCod" class="btn btn-outline-danger">
                        <i class="bi bi-trash"></i> Eliminar
                    </a>
                }
            </div>
        </div>
    </div>
</div>
