@model comara.Models.ViewModels.ReporteCuentasCorrientesViewModel

@{
    ViewData["Title"] = "Reporte de Cuentas Corrientes";
}

<h1>Reporte de Cuentas Corrientes</h1>

<!-- Filtros -->
<div class="card mb-4">
    <div class="card-header">
        <i class="bi bi-filter"></i> Filtros
    </div>
    <div class="card-body">
        <form method="get" asp-action="CuentasCorrientes">
            <div class="row g-3">
                <div class="col-md-2">
                    <label class="form-label">Fecha Desde</label>
                    <input type="date" name="fechaDesde" class="form-control" value="@Model.FechaDesde?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Fecha Hasta</label>
                    <input type="date" name="fechaHasta" class="form-control" value="@Model.FechaHasta?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Cliente</label>
                    <select name="clienteId" class="form-select" asp-items="ViewBag.Clientes as SelectList">
                        <option value="">-- Todos --</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Tipo Movimiento</label>
                    <select name="tipoMovimiento" class="form-select" asp-items="ViewBag.TiposMovimiento as SelectList">
                        <option value="">-- Todos --</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-primary">Filtrar</button>
                    <a asp-action="CuentasCorrientes" class="btn btn-outline-secondary">Limpiar</a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Resumen -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="card bg-danger text-white">
            <div class="card-body">
                <h5 class="card-title">Total DEBE</h5>
                <h3>@Model.TotalDebe.ToString("C")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-success text-white">
            <div class="card-body">
                <h5 class="card-title">Total HABER</h5>
                <h3>@Model.TotalHaber.ToString("C")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-info text-white">
            <div class="card-body">
                <h5 class="card-title">Saldo Pendiente</h5>
                <h3>@((Model.TotalDebe - Model.TotalHaber).ToString("C"))</h3>
            </div>
        </div>
    </div>
</div>

<!-- Tabla -->
<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Fecha</th>
                <th>Cliente</th>
                <th>Tipo</th>
                <th class="text-end">Monto</th>
                <th class="text-end">Saldo</th>
                <th>Descripcion</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Movimientos.Any())
            {
                @foreach (var item in Model.Movimientos)
                {
                    <tr>
                        <td>@item.CctaFech.ToString("dd/MM/yyyy")</td>
                        <td>@item.ClienteNombre</td>
                        <td>
                            @if (item.Movimiento == "DEBE")
                            {
                                <span class="badge bg-danger">DEBE</span>
                            }
                            else
                            {
                                <span class="badge bg-success">HABER</span>
                            }
                        </td>
                        <td class="text-end">@item.Monto.ToString("C")</td>
                        <td class="text-end"><strong>@item.Saldo.ToString("C")</strong></td>
                        <td>@item.Descripcion</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">No se encontraron movimientos con los filtros seleccionados</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Paginacion -->
@if (Model.TotalPaginas > 1)
{
    <nav aria-label="Paginacion de cuentas corrientes">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.TienePaginaAnterior ? "" : "disabled")">
                <a class="page-link" asp-action="CuentasCorrientes"
                   asp-route-pagina="@(Model.PaginaActual - 1)"
                   asp-route-fechaDesde="@Model.FechaDesde?.ToString("yyyy-MM-dd")"
                   asp-route-fechaHasta="@Model.FechaHasta?.ToString("yyyy-MM-dd")"
                   asp-route-clienteId="@Model.ClienteId"
                   asp-route-tipoMovimiento="@Model.TipoMovimiento">Anterior</a>
            </li>

            @for (int i = Math.Max(1, Model.PaginaActual - 2); i <= Math.Min(Model.TotalPaginas, Model.PaginaActual + 2); i++)
            {
                <li class="page-item @(i == Model.PaginaActual ? "active" : "")">
                    <a class="page-link" asp-action="CuentasCorrientes"
                       asp-route-pagina="@i"
                       asp-route-fechaDesde="@Model.FechaDesde?.ToString("yyyy-MM-dd")"
                       asp-route-fechaHasta="@Model.FechaHasta?.ToString("yyyy-MM-dd")"
                       asp-route-clienteId="@Model.ClienteId"
                       asp-route-tipoMovimiento="@Model.TipoMovimiento">@i</a>
                </li>
            }

            <li class="page-item @(Model.TienePaginaSiguiente ? "" : "disabled")">
                <a class="page-link" asp-action="CuentasCorrientes"
                   asp-route-pagina="@(Model.PaginaActual + 1)"
                   asp-route-fechaDesde="@Model.FechaDesde?.ToString("yyyy-MM-dd")"
                   asp-route-fechaHasta="@Model.FechaHasta?.ToString("yyyy-MM-dd")"
                   asp-route-clienteId="@Model.ClienteId"
                   asp-route-tipoMovimiento="@Model.TipoMovimiento">Siguiente</a>
            </li>
        </ul>
    </nav>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-sm btn-secondary">Volver a Reportes</a>
</div>
