@model IEnumerable<comara.Models.ViewModels.StockReporteItem>

@{
    ViewData["Title"] = "Reporte de Stock Critico";
}

@functions {
    string FormatStock(decimal? value)
    {
        if (value == null) return "-";
        // Si no tiene decimales, mostrar como entero
        if (value == Math.Floor(value.Value))
            return ((int)value.Value).ToString();
        // Si tiene decimales, mostrar con 2 decimales
        return value.Value.ToString("N2");
    }
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Reporte de Stock Critico</h1>
        <span class="badge bg-danger fs-5">@Model.Count() articulos en estado critico</span>
    </div>

    @if (Model.Any())
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i>
            Los siguientes articulos tienen stock igual o inferior a su stock minimo configurado.
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Codigo</th>
                        <th>Descripcion</th>
                        <th>Marca</th>
                        <th class="text-end">Stock Actual</th>
                        <th class="text-end">Stock Minimo</th>
                        <th class="text-end">Diferencia</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var diferencia = item.ArtStock - item.ArtStockMin;
                        <tr class="@(item.ArtStock == 0 ? "table-danger" : "table-warning")">
                            <td>@item.ArtCod</td>
                            <td>@item.ArtDesc</td>
                            <td>@(item.MarcaNombre ?? "-")</td>
                            <td class="text-end">
                                <strong>@FormatStock(item.ArtStock)</strong>
                            </td>
                            <td class="text-end">@FormatStock(item.ArtStockMin)</td>
                            <td class="text-end">
                                <span class="text-danger">@FormatStock(diferencia)</span>
                            </td>
                            <td>
                                @if (item.ArtStock == 0)
                                {
                                    <span class="badge bg-danger">Sin stock</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Bajo</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-success">
            <i class="bi bi-check-circle"></i>
            No hay articulos en estado critico. Todos los productos tienen stock suficiente.
        </div>
    }

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">Volver a Reportes</a>
        <a asp-action="ReporteStock" class="btn btn-primary">Ver Reporte Completo de Stock</a>
    </div>
</div>
