@model comara.Models.ViewModels.ReporteVentasViewModel

@{
    ViewData["Title"] = "Reporte de Ventas";
}

<h1>Reporte de Ventas</h1>

<!-- Filtros -->
<div class="card mb-4">
    <div class="card-header">
        <i class="bi bi-filter"></i> Filtros
    </div>
    <div class="card-body">
        <form method="get" asp-action="Ventas">
            <div class="row g-3">
                <div class="col-md-2">
                    <label class="form-label">Fecha Desde</label>
                    <input type="date" name="fechaDesde" class="form-control" value="@Model.FechaDesde?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Fecha Hasta</label>
                    <input type="date" name="fechaHasta" class="form-control" value="@Model.FechaHasta?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Cliente</label>
                    <select name="clienteId" class="form-select" asp-items="ViewBag.Clientes as SelectList">
                        <option value="">-- Todos --</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Metodo Pago</label>
                    <select name="metodoPagoId" class="form-select" asp-items="ViewBag.MetodosPago as SelectList">
                        <option value="">-- Todos --</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Estado</label>
                    <select name="estadoId" class="form-select" asp-items="ViewBag.Estados as SelectList">
                        <option value="">-- Todos --</option>
                    </select>
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Filtrar</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Resumen -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <h5 class="card-title">Total Ventas</h5>
                <h3>@Model.TotalVentas.ToString("C")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-info text-white">
            <div class="card-body">
                <h5 class="card-title">Costo Total</h5>
                <h3 class="fw-bold">
                    @Model.GranTotalCostos.ToString("C")
                    <span class="fs-6 text-dark opacity-75">
                        (@Model.MargenGeneral.ToString("0.00")%)
                    </span>
                </h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-success text-white">
            <div class="card-body">
                <h5 class="card-title">Cantidad de Ventas</h5>
                <h3>@Model.CantidadVentas</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-info text-white">
            <div class="card-body">
                <h5 class="card-title">Mostrando</h5>
                <h3>Pagina @Model.PaginaActual de @Model.TotalPaginas</h3>
            </div>
        </div>
    </div>
</div>

<!-- Tabla -->
<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>N Venta</th>
                <th>Fecha</th>
                <th>Cliente</th>
                <th>Metodo Pago</th>
                <th>Costo Total / Margen</th>
                <th class="text-end">Total</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Ventas.Any())
            {
                @foreach (var item in Model.Ventas)
                {
                    <tr>
                        <td>@item.VenCod</td>
                        <td>@item.VenFech.ToString("dd/MM/yyyy")</td>
                        <td>@item.ClienteNombre</td>
                        <td>@item.MetodoPago</td>
                        <td>
                            @if (item.CostoTotal > 0)
                            {
                                @item.CostoTotal.ToString("C")
                                <span class="text-success fw-bold" style="font-size: 0.85em;">
                                    (@item.MargenPorcentaje.ToString("0.00")%)
                                </span>
                            }
                            else
                            {
                                <span class="text-muted fst-italic" style="font-size: 0.85em;">N/A</span>
                            }
                        </td>
                        <td class="text-end">@item.VenTotal.ToString("C")</td>
                        <td>
                            @if (item.Estado == "Completada")
                            {
                                <span class="badge bg-success">@item.Estado</span>
                            }
                            else if (item.Estado == "Pendiente")
                            {
                                <span class="badge bg-warning text-dark">@item.Estado</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@(string.IsNullOrEmpty(item.Estado) ? "Sin estado" : item.Estado)</span>
                            }
                        </td>
                        <td>
                            <a asp-controller="Ventas" asp-action="Details" asp-route-id="@item.VenCod" class="btn btn-sm btn-info">Ver Detalle</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">No se encontraron ventas con los filtros seleccionados</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Paginacion -->
@if (Model.TotalPaginas > 1)
{
    <nav aria-label="Paginacion de ventas">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.TienePaginaAnterior ? "" : "disabled")">
                <a class="page-link" asp-action="Ventas"
                   asp-route-pagina="@(Model.PaginaActual - 1)"
                   asp-route-fechaDesde="@Model.FechaDesde?.ToString("yyyy-MM-dd")"
                   asp-route-fechaHasta="@Model.FechaHasta?.ToString("yyyy-MM-dd")"
                   asp-route-clienteId="@Model.ClienteId"
                   asp-route-metodoPagoId="@Model.MetodoPagoId"
                   asp-route-estadoId="@Model.EstadoId">Anterior</a>
            </li>

            @for (int i = Math.Max(1, Model.PaginaActual - 2); i <= Math.Min(Model.TotalPaginas, Model.PaginaActual + 2); i++)
            {
                <li class="page-item @(i == Model.PaginaActual ? "active" : "")">
                    <a class="page-link" asp-action="Ventas"
                       asp-route-pagina="@i"
                       asp-route-fechaDesde="@Model.FechaDesde?.ToString("yyyy-MM-dd")"
                       asp-route-fechaHasta="@Model.FechaHasta?.ToString("yyyy-MM-dd")"
                       asp-route-clienteId="@Model.ClienteId"
                       asp-route-metodoPagoId="@Model.MetodoPagoId"
                       asp-route-estadoId="@Model.EstadoId">@i</a>
                </li>
            }

            <li class="page-item @(Model.TienePaginaSiguiente ? "" : "disabled")">
                <a class="page-link" asp-action="Ventas"
                   asp-route-pagina="@(Model.PaginaActual + 1)"
                   asp-route-fechaDesde="@Model.FechaDesde?.ToString("yyyy-MM-dd")"
                   asp-route-fechaHasta="@Model.FechaHasta?.ToString("yyyy-MM-dd")"
                   asp-route-clienteId="@Model.ClienteId"
                   asp-route-metodoPagoId="@Model.MetodoPagoId"
                   asp-route-estadoId="@Model.EstadoId">Siguiente</a>
            </li>
        </ul>
    </nav>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-sm btn-secondary">Volver a Reportes</a>
    <a asp-controller="Ventas" asp-action="Index" class="btn btn-sm btn-primary">Ir a Ventas</a>
</div>
