@model comara.Models.ViewModels.ReporteStockViewModel

@{
    ViewData["Title"] = "Reporte de Stock";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Reporte de Stock</h1>
        <button onclick="window.print()" class="btn btn-primary no-print">
            <i class="bi bi-printer"></i> Imprimir
        </button>
    </div>

    <!-- Filtros -->
    <div class="card mb-4 no-print">
        <div class="card-header">
            <i class="bi bi-filter"></i> Filtros
        </div>
        <div class="card-body">
            <form method="get" asp-action="ReporteStock">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Buscar</label>
                        <input type="text" name="busqueda" class="form-control" placeholder="Descripcion o codigo..." value="@Model.Busqueda" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Marca</label>
                        <select name="marcaId" class="form-select" asp-items="ViewBag.Marcas as SelectList">
                            <option value="">-- Todas --</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Proveedor</label>
                        <select name="proveedorId" class="form-select" asp-items="ViewBag.Proveedores as SelectList">
                            <option value="">-- Todos --</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Stock Critico</label>
                        <select name="soloStockCritico" class="form-select">
                            <option value="">-- Todos --</option>
                            <option value="true" selected="@(Model.SoloStockCritico == true)">Solo criticos</option>
                        </select>
                    </div>
                    <div class="col-md-2 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-primary">Filtrar</button>
                        <a asp-action="ReporteStock" class="btn btn-outline-secondary">Limpiar</a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Resumen -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h5 class="card-title">Total Articulos</h5>
                    <h3>@Model.TotalArticulos</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-warning text-dark">
                <div class="card-body">
                    <h5 class="card-title">Stock Critico</h5>
                    <h3>@Model.ArticulosStockCritico</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5 class="card-title">Valor Total Stock</h5>
                    <h3>@Model.ValorTotalStock.ToString("C")</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla -->
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Codigo</th>
                    <th>Descripcion</th>
                    <th>Marca</th>
                    <th>Proveedor</th>
                    <th class="text-end">Stock</th>
                    <th class="text-end">Stock Min.</th>
                    <th class="text-end">Costo Neto</th>
                    <th class="text-end">Costo c/Desc</th>
                    <th class="text-end">Costo Final</th>
                    <th class="text-end">Valor Stock</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Articulos.Any())
                {
                    @foreach (var item in Model.Articulos)
                    {
                        <tr class="@(item.EsCritico ? "table-warning" : "")">
                            <td>@item.ArtCod</td>
                            <td>@item.ArtDesc</td>
                            <td>@(item.MarcaNombre ?? "-")</td>
                            <td>@(item.ProveedorNombre ?? "-")</td>
                            <td class="text-end">@(item.ArtStock == Math.Truncate(item.ArtStock) ? item.ArtStock.ToString("N0") : item.ArtStock.ToString("N2"))</td>
                            <td class="text-end">@(item.ArtStockMin == Math.Truncate(item.ArtStockMin) ? item.ArtStockMin.ToString("N0") : item.ArtStockMin.ToString("N2"))</td>
                            <td class="text-end">@string.Format("${0:N2}", item.CostoNeto)</td>
                            <td class="text-end">
                                @string.Format("${0:N2}", item.CostoConDescuento)
                                @if (item.DescuentoProveedor > 0)
                                {
                                    <small class="text-success">(-@string.Format("{0:N2}", item.DescuentoProveedor)%)</small>
                                }
                            </td>
                            <td class="text-end">
                                @string.Format("${0:N2}", item.CostoFinal)
                                @if (item.PorcentajeIva > 0)
                                {
                                    <small class="text-info">(+@string.Format("{0:N2}", item.PorcentajeIva)% IVA)</small>
                                }
                            </td>
                            <td class="text-end">@item.ValorStock.ToString("C")</td>
                            <td>
                                @if (item.EsCritico)
                                {
                                    <span class="badge bg-danger">Critico</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">OK</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="11" class="text-center text-muted">No se encontraron articulos con los filtros seleccionados</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Paginacion -->
    @if (Model.TotalPaginas > 1)
    {
        <nav aria-label="Paginacion de stock" class="no-print">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.TienePaginaAnterior ? "" : "disabled")">
                    <a class="page-link" asp-action="ReporteStock"
                       asp-route-pagina="@(Model.PaginaActual - 1)"
                       asp-route-marcaId="@Model.MarcaId"
                       asp-route-proveedorId="@Model.ProveedorId"
                       asp-route-soloStockCritico="@Model.SoloStockCritico"
                       asp-route-busqueda="@Model.Busqueda">Anterior</a>
                </li>

                @for (int i = Math.Max(1, Model.PaginaActual - 2); i <= Math.Min(Model.TotalPaginas, Model.PaginaActual + 2); i++)
                {
                    <li class="page-item @(i == Model.PaginaActual ? "active" : "")">
                        <a class="page-link" asp-action="ReporteStock"
                           asp-route-pagina="@i"
                           asp-route-marcaId="@Model.MarcaId"
                           asp-route-proveedorId="@Model.ProveedorId"
                           asp-route-soloStockCritico="@Model.SoloStockCritico"
                           asp-route-busqueda="@Model.Busqueda">@i</a>
                    </li>
                }

                <li class="page-item @(Model.TienePaginaSiguiente ? "" : "disabled")">
                    <a class="page-link" asp-action="ReporteStock"
                       asp-route-pagina="@(Model.PaginaActual + 1)"
                       asp-route-marcaId="@Model.MarcaId"
                       asp-route-proveedorId="@Model.ProveedorId"
                       asp-route-soloStockCritico="@Model.SoloStockCritico"
                       asp-route-busqueda="@Model.Busqueda">Siguiente</a>
                </li>
            </ul>
        </nav>
    }

    <div class="mt-3 no-print">
        <a asp-action="Index" class="btn btn-sm btn-secondary">Volver a Reportes</a>
        <a asp-action="StockCritico" class="btn btn-sm btn-warning">Ver Solo Stock Critico</a>
    </div>
</div>

<style>
    /* Romper el container fijo del layout solo en esta página */
    .container {
        max-width: 100% !important;
        padding-left: 1.5rem;
        padding-right: 1.5rem;
    }

    @@media print {
        .no-print {
            display: none !important;
        }
        .table {
            font-size: 10pt;
        }
        .card {
            border: 1px solid #000;
        }
    }
</style>
