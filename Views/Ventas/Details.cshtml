@model comara.Models.Venta

@{
    ViewData["Title"] = "Detalles";
}

<h1>Detalles de la Venta</h1>

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-5">Fecha:</dt>
            <dd class="col-sm-7">@Model.VenFech.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-5">Cliente:</dt>
            <dd class="col-sm-7">@Model.Cliente?.CliNombre</dd>

            <dt class="col-sm-5">Estado:</dt>
            <dd class="col-sm-7">@Model.TipoEstado?.Descripcion</dd>

            <dt class="col-sm-5">Metodo de Pago:</dt>
            <dd class="col-sm-7">
                @if (Model.Pagos != null && Model.Pagos.Any())
                {
                    var metodosPago = Model.Pagos
                        .Where(p => p.TipoMetodoPago != null)
                        .Select(p => p.TipoMetodoPago!.Descripcion)
                        .Distinct()
                        .ToList();
                    if (metodosPago.Any())
                    {
                        foreach (var metodo in metodosPago)
                        {
                            <span class="badge bg-info me-1">@metodo</span>
                        }
                    }
                    else
                    {
                        @(Model.TipoMetodoPago?.Descripcion ?? "No especificado")
                    }
                }
                else
                {
                    @(Model.TipoMetodoPago?.Descripcion ?? "No especificado")
                }
            </dd>

            <dt class="col-sm-5">Lista de Precio:</dt>
            <dd class="col-sm-7">@(Model.Lista?.ListDesc ?? "No especificado")</dd>

            <dt class="col-sm-5">Tipo Comprobante:</dt>
            <dd class="col-sm-7">@(Model.TipoComprobante?.Descripcion ?? "No especificado")</dd>

            @if (!string.IsNullOrEmpty(Model.VenCAE))
            {
                <dt class="col-sm-5">CAE:</dt>
                <dd class="col-sm-7">@Model.VenCAE</dd>

                <dt class="col-sm-5">Vencimiento CAE:</dt>
                <dd class="col-sm-7">@Model.VenCAEVencimiento?.ToString("dd/MM/yyyy")</dd>

                <dt class="col-sm-5">Estado de Pago:</dt>
                <dd class="col-sm-7">
                    @if (Model.VenEstadoPago == 3)
                    {
                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Pagada</span>
                    }
                    else if (Model.VenEstadoPago == 2)
                    {
                        <span class="badge bg-warning text-dark"><i class="bi bi-clock-history"></i> Parcialmente Pagada</span>
                    }
                    else
                    {
                        <span class="badge bg-danger"><i class="bi bi-exclamation-circle"></i> Pendiente de Pago</span>
                    }
                </dd>
            }
        </dl>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Información del Cliente</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-6">Documento:</dt>
                    <dd class="col-sm-6">@(Model.Cliente?.CliNumDoc ?? "No especificado")</dd>

                    <dt class="col-sm-6">Teléfono:</dt>
                    <dd class="col-sm-6">@(Model.Cliente?.CliTelefono ?? "No especificado")</dd>

                    <dt class="col-sm-6">Email:</dt>
                    <dd class="col-sm-6">@(Model.Cliente?.CliEmail ?? "No especificado")</dd>

                    <dt class="col-sm-6">Dirección:</dt>
                    <dd class="col-sm-6">@(Model.Cliente?.CliDireccion ?? "No especificada")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Productos de la Venta</h5>
            </div>
            <div class="card-body">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Descripción</th>
                            <th>Marca</th>
                            <th>Cantidad</th>
                            <th>Precio Unitario</th>
                            <th>Costo Total / Mg. Ganancia</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var detalle in Model.DetalleVentas)
                        {
                            decimal margenPorcentaje = 0;
                            if (detalle.DetSubtotal > 0 && detalle.DetCostoTotal > 0)
                            {
                                margenPorcentaje = ((detalle.DetSubtotal - detalle.DetCostoTotal) / detalle.DetSubtotal) * 100;
                            }
                            <tr>
                                <td>@detalle.Articulo?.Id</td>
                                <td>@detalle.Articulo?.ArtDesc</td>
                                <td>@(detalle.Articulo?.Marca?.marNombre ?? "Sin marca")</td>
                                <td>
                                    @(detalle.DetCant == Math.Truncate(detalle.DetCant) ? detalle.DetCant.ToString("N0") : detalle.DetCant.ToString("N2"))
                                </td>
                                <td>@string.Format("${0:N2}", detalle.DetPrecio)</td>
                                <td>
                                    @if (detalle.DetCostoTotal > 0)
                                    {
                                        @detalle.DetCostoTotal.ToString("C")
                                        <span class="text-success fw-bold" style="font-size: 0.85em;">(@margenPorcentaje.ToString("0.00")%)</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic" style="font-size: 0.85em;">N/A (Venta antigua)</span>
                                    }
                                </td>
                                <td>@string.Format("${0:N2}", detalle.DetSubtotal)</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        @{
                            decimal sumaCostoTotal = Model.DetalleVentas.Sum(d => d.DetCostoTotal);
                            decimal sumaSubtotalVenta = Model.DetalleVentas.Sum(d => d.DetSubtotal);
                            decimal margenVentaTotal = 0;
    
                            if (sumaSubtotalVenta > 0 && sumaCostoTotal > 0)
                            {
                                margenVentaTotal = ((sumaSubtotalVenta - sumaCostoTotal) / sumaSubtotalVenta) * 100;
                            }
                        }
                        <tr>
                            <td colspan="4" class="text-end fw-bold">TOTALES GENERALES:</td>
                            <td class="fw-bold fs-5">
                                @if (sumaCostoTotal > 0)
                                {
                                    @sumaCostoTotal.ToString("C")
                                    <span class="text-success">(@margenVentaTotal.ToString("0.00")%)</span>
                                }
                                else
                                {
                                    <span class="text-muted fs-6">N/A</span>
                                }
                            </td>
                            <td class="fw-bold fs-5">@sumaSubtotalVenta.ToString("C")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.VenCAE) && Model.Pagos != null && Model.Pagos.Any())
{
    var totalPagado = Model.Pagos.Sum(p => p.PagMonto);
    var saldoPendiente = Model.VenTotal - totalPagado;

    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-cash-coin"></i> Pagos Realizados</h5>
                    <span class="badge bg-light text-dark">Total: $@string.Format("{0:N2}", totalPagado)</span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-striped mb-0">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Metodo</th>
                                <th class="text-end">Monto</th>
                                <th>Descripcion</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pago in Model.Pagos.OrderByDescending(p => p.PagFech))
                            {
                                <tr>
                                    <td>@pago.PagFech.ToString("dd/MM/yyyy")</td>
                                    <td><span class="badge bg-secondary">@pago.TipoMetodoPago?.Descripcion</span></td>
                                    <td class="text-end text-success"><strong>$@string.Format("{0:N2}", pago.PagMonto)</strong></td>
                                    <td>@pago.PagDesc</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-info">
                                <td colspan="2"><strong>Total Factura:</strong></td>
                                <td class="text-end"><strong>$@string.Format("{0:N2}", Model.VenTotal)</strong></td>
                                <td></td>
                            </tr>
                            <tr class="table-success">
                                <td colspan="2"><strong>Total Pagado:</strong></td>
                                <td class="text-end"><strong>$@string.Format("{0:N2}", totalPagado)</strong></td>
                                <td></td>
                            </tr>
                            @if (saldoPendiente > 0)
                            {
                                <tr class="table-danger">
                                    <td colspan="2"><strong>Saldo Pendiente:</strong></td>
                                    <td class="text-end"><strong>$@string.Format("{0:N2}", saldoPendiente)</strong></td>
                                    <td></td>
                                </tr>
                            }
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

<div class="mt-3">
    @if (Model.VenEstado == 2)
    {
        <a asp-action="Edit" asp-route-id="@Model.VenCod" class="btn btn-sm btn-warning">Editar</a>
        <span>|</span>
    }
    @if (Model.VenEstado == 1 && string.IsNullOrEmpty(Model.VenCAE))
    {
        <a asp-action="DescargarPresupuestoPDF" asp-route-id="@Model.VenCod" class="btn btn-sm btn-danger" title="Descargar PDF del Presupuesto">
            <i class="bi bi-file-earmark-pdf"></i> Imprimir Presupuesto
        </a>
        <span>|</span>
    }
    <a asp-action="Index" class="btn btn-sm btn-secondary">Volver a la lista</a>
    <span>|</span>
    @if (Model.VenEstado == 2 && string.IsNullOrEmpty(Model.VenCAE))
    {
        <a asp-controller="Facturas" asp-action="Generar" asp-route-id="@Model.VenCod"
           class="btn btn-sm btn-success">
            <i class="bi bi-file-earmark-check"></i> Facturar con AFIP
        </a>
        <span>|</span>
    }

    @if (!string.IsNullOrEmpty(Model.VenCAE))
    {
        <a asp-controller="Facturas" asp-action="DescargarPDF" asp-route-id="@Model.VenCod"
           class="btn btn-sm btn-danger">
            <i class="bi bi-file-earmark-pdf"></i> Descargar Factura PDF
        </a>
        @if (Model.VenEstadoPago != 3)
        {
            <a asp-action="RegistrarPagoFactura" asp-route-id="@Model.VenCod"
               class="btn btn-sm btn-success">
                <i class="bi bi-cash-coin"></i> Registrar Pago
            </a>
            <span>|</span>
        }
    }
</div>
