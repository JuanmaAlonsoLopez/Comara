@model comara.Models.ViewModels.GenerarPresupuestoViewModel

@{
    ViewData["Title"] = "Generar Presupuesto";
}

<h1>Generar Presupuesto</h1>

<hr />

@if (Model.Venta != null)
{
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Resumen de la Venta</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <dl class="row">
                        <dt class="col-sm-4">Venta #:</dt>
                        <dd class="col-sm-8">@Model.Venta.VenCod</dd>

                        <dt class="col-sm-4">Fecha:</dt>
                        <dd class="col-sm-8">@Model.Venta.VenFech.ToString("dd/MM/yyyy")</dd>

                        <dt class="col-sm-4">Cliente:</dt>
                        <dd class="col-sm-8">@(Model.Venta.Cliente?.CliNombre ?? "Sin cliente")</dd>

                        <dt class="col-sm-4">Estado:</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-warning">@(Model.Venta.TipoEstado?.Descripcion ?? "Sin estado")</span>
                        </dd>
                    </dl>
                </div>
                <div class="col-md-6">
                    <h4 class="text-end">
                        <span class="badge bg-success">Total: $@string.Format("{0:N2}", Model.Venta.VenTotal)</span>
                    </h4>
                </div>
            </div>

            <hr />

            <h6>Artículos:</h6>
            <table class="table table-sm table-striped">
                <thead>
                    <tr>
                        <th>Cantidad</th>
                        <th>Descripción</th>
                        <th class="text-end">Precio Unit.</th>
                        <th class="text-end">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var detalle in Model.Venta.DetalleVentas ?? Enumerable.Empty<comara.Models.DetalleVenta>())
                    {
                        <tr>
                            <td>@detalle.DetCant</td>
                            <td>@(detalle.Articulo?.ArtDesc ?? "Sin descripción")</td>
                            <td class="text-end">$@string.Format("{0:N2}", detalle.DetPrecio)</td>
                            <td class="text-end">$@string.Format("{0:N2}", detalle.DetSubtotal)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="card">
    <div class="card-header bg-info text-white">
        <h5 class="mb-0">Seleccionar Método de Pago</h5>
    </div>
    <div class="card-body">
        <form asp-action="Presupuesto" method="post">
            <input type="hidden" asp-for="VenCod" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="MetodoPago" class="control-label"></label>
                <select asp-for="MetodoPago" class="form-control" asp-items="ViewBag.MetodosPago">
                    <option value="">-- Seleccione un método de pago --</option>
                </select>
                <span asp-validation-for="MetodoPago" class="text-danger"></span>
            </div>

            <div class="alert alert-info" role="alert">
                <i class="bi bi-info-circle"></i>
                <strong>Nota:</strong> Al generar el presupuesto:
                <ul class="mb-0 mt-2">
                    <li>El estado de la venta cambiará a "Completada"</li>
                    <li>Se generará un PDF con el resumen del presupuesto</li>
                    <li>No se registrará automáticamente en Caja (hazlo desde Caja > Registrar Pago)</li>
                    <li>No se interactuará con AFIP (no se generará CAE)</li>
                </ul>
            </div>

            <div class="form-group mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-file-earmark-pdf"></i> Generar Presupuesto
                </button>
                <a asp-action="Details" asp-route-id="@Model.VenCod" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
