@model IEnumerable<comara.Models.Venta>

@{
    ViewData["Title"] = "Ventas";
    var estados = ViewBag.Estados as List<comara.Models.VentaTipoEstado> ?? new List<comara.Models.VentaTipoEstado>();
    var estadosPago = ViewBag.EstadosPago as List<comara.Models.VentaEstadoPago> ?? new List<comara.Models.VentaEstadoPago>();
}

<h1><i class="bi bi-cart"></i> Ventas</h1>

<p>
    <a asp-action="Create" class="btn btn-sm btn-primary">
        <i class="bi bi-plus-circle"></i> Crear Nueva Venta
    </a>
</p>

<!-- Filtros -->
<form method="get" asp-action="Index" class="mb-3">
    <div class="row g-2">
        <div class="col-md-3">
            <div class="input-group">
                <input type="text" name="searchTerm" class="form-control"
                       value="@ViewBag.SearchTerm"
                       placeholder="Buscar por cliente, ID o CAE..." />
                <button type="submit" class="btn btn-outline-primary">
                    <i class="bi bi-search"></i>
                </button>
            </div>
        </div>
        <div class="col-md-2">
            <select name="estadoFilter" class="form-select" onchange="this.form.submit()">
                <option value="">Todos los estados</option>
                @foreach (var estado in estados)
                {
                    <option value="@estado.Id" selected="@(ViewBag.EstadoFilter != null && (int?)ViewBag.EstadoFilter == estado.Id)">@estado.Descripcion</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="estadoPagoFilter" class="form-select" onchange="this.form.submit()">
                <option value="">Estado de pago</option>
                @foreach (var ep in estadosPago)
                {
                    <option value="@ep.Id" selected="@(ViewBag.EstadoPagoFilter != null && (int?)ViewBag.EstadoPagoFilter == ep.Id)">@ep.Descripcion</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <input type="date" name="fechaDesde" class="form-control"
                   value="@ViewBag.FechaDesde" placeholder="Desde" title="Fecha desde" />
        </div>
        <div class="col-md-2">
            <input type="date" name="fechaHasta" class="form-control"
                   value="@ViewBag.FechaHasta" placeholder="Hasta" title="Fecha hasta" />
        </div>
        <div class="col-md-1">
            @if (!string.IsNullOrEmpty(ViewBag.SearchTerm) || ViewBag.EstadoFilter != null ||
                 ViewBag.EstadoPagoFilter != null || ViewBag.FechaDesde != null || ViewBag.FechaHasta != null)
            {
                <a asp-action="Index" class="btn btn-outline-secondary w-100" title="Limpiar filtros">
                    <i class="bi bi-x-circle"></i>
                </a>
            }
        </div>
    </div>
    <input type="hidden" name="pageSize" value="@ViewBag.PageSize" />
</form>

<!-- Info de resultados -->
<div class="d-flex justify-content-between align-items-center mb-2">
    <small class="text-muted">
        @if (ViewBag.TotalItems > 0)
        {
            <span>Mostrando @((ViewBag.CurrentPage - 1) * ViewBag.PageSize + 1)-@Math.Min(ViewBag.CurrentPage * ViewBag.PageSize, ViewBag.TotalItems) de @ViewBag.TotalItems ventas</span>
        }
        else
        {
            <span>No se encontraron ventas</span>
        }
        @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
        {
            <span> (filtrado por: "@ViewBag.SearchTerm")</span>
        }
    </small>
    <div>
        <label class="me-2">Por pagina:</label>
        <select id="pageSizeSelect" class="form-select form-select-sm d-inline-block" style="width: auto;">
            <option value="20" selected="@(ViewBag.PageSize == 20)">20</option>
            <option value="50" selected="@(ViewBag.PageSize == 50)">50</option>
            <option value="100" selected="@(ViewBag.PageSize == 100)">100</option>
        </select>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="table-responsive">
    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th style="width: 70px;">ID</th>
                <th>Fecha</th>
                <th>Cliente</th>
                <th class="text-end">Total</th>
                <th>Tipo Factura</th>
                <th>Estado</th>
                <th>CAE</th>
                <th>Estado Pago</th>
                <th style="width: 280px;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>#@item.VenCod</strong></td>
                    <td>@item.VenFech.ToString("dd/MM/yyyy")</td>
                    <td>@(item.Cliente?.CliNombre ?? "Sin cliente")</td>
                    <td class="text-end"><strong class="text-success">$@string.Format("{0:N2}", item.VenTotal)</strong></td>
                    <td>
                        @if (item.TipoComprobante != null)
                        {
                            <span class="badge bg-info">@item.TipoComprobante.Descripcion</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Sin asignar</span>
                        }
                    </td>
                    <td>@(item.TipoEstado?.Descripcion ?? "Sin estado")</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.VenCAE))
                        {
                            <span class="badge bg-success" title="CAE: @item.VenCAE - Vto: @item.VenCAEVencimiento?.ToString("dd/MM/yyyy")">
                                <i class="bi bi-check-circle"></i> @item.VenCAE.Substring(0, Math.Min(10, item.VenCAE.Length))...
                            </span>
                        }
                        else if (item.VenEstado == 1)
                        {
                            <span class="badge bg-secondary">Presupuesto</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Sin CAE</span>
                        }
                    </td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.VenCAE))
                        {
                            @if (item.VenEstadoPago == 3)
                            {
                                <span class="badge bg-success"><i class="bi bi-check-circle"></i> Pagada</span>
                            }
                            else if (item.VenEstadoPago == 2)
                            {
                                <span class="badge bg-warning text-dark"><i class="bi bi-clock-history"></i> Parcial</span>
                            }
                            else
                            {
                                <span class="badge bg-danger"><i class="bi bi-exclamation-circle"></i> Pendiente</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td class="text-nowrap">
                        <div class="btn-group btn-group-sm" role="group">
                            <a asp-action="Details" asp-route-id="@item.VenCod" class="btn btn-info" title="Ver Detalles">
                                <i class="bi bi-eye"></i>
                            </a>
                            @if (item.VenEstado == 2)
                            {
                                <a asp-action="Edit" asp-route-id="@item.VenCod" class="btn btn-warning" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <div class="btn-group btn-group-sm" role="group">
                                    <button type="button" class="btn btn-success dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" title="Generar documento">
                                        <i class="bi bi-file-earmark-plus"></i>
                                    </button>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-controller="Facturas" asp-action="Generar" asp-route-id="@item.VenCod">Factura</a></li>
                                        <li><a class="dropdown-item" asp-action="Presupuesto" asp-route-id="@item.VenCod">Presupuesto</a></li>
                                    </ul>
                                </div>
                            }
                            @if (item.VenEstado == 1 && string.IsNullOrEmpty(item.VenCAE))
                            {
                                <a asp-action="DescargarPresupuestoPDF" asp-route-id="@item.VenCod" class="btn btn-danger" title="Descargar PDF del Presupuesto">
                                    <i class="bi bi-file-earmark-pdf"></i>
                                </a>
                            }
                            @if (!string.IsNullOrEmpty(item.VenCAE) && item.VenEstadoPago != 3)
                            {
                                <a asp-action="RegistrarPagoFactura" asp-route-id="@item.VenCod" class="btn btn-success" title="Registrar Pago">
                                    <i class="bi bi-cash-coin"></i>
                                </a>
                            }
                            <a asp-action="Delete" asp-route-id="@item.VenCod" class="btn btn-outline-danger" title="Eliminar">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Paginacion -->
@if (ViewBag.TotalPages > 1)
{
    <nav aria-label="Paginacion de ventas" class="mt-3">
        <ul class="pagination justify-content-center">
            @{
                int currentPage = ViewBag.CurrentPage;
                int totalPages = ViewBag.TotalPages;
                string searchTerm = ViewBag.SearchTerm ?? "";
                int? estadoFilterValue = ViewBag.EstadoFilter;
                string estadoFilter = estadoFilterValue?.ToString() ?? "";
                int? estadoPagoFilterValue = ViewBag.EstadoPagoFilter;
                string estadoPagoFilter = estadoPagoFilterValue?.ToString() ?? "";
                string fechaDesde = ViewBag.FechaDesde ?? "";
                string fechaHasta = ViewBag.FechaHasta ?? "";
                int pageSize = ViewBag.PageSize;

                int startPage = Math.Max(1, currentPage - 2);
                int endPage = Math.Min(totalPages, currentPage + 2);

                if (endPage - startPage < 4)
                {
                    if (startPage == 1)
                        endPage = Math.Min(totalPages, startPage + 4);
                    else if (endPage == totalPages)
                        startPage = Math.Max(1, endPage - 4);
                }
            }

            <!-- Primera pagina y anterior -->
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="1" asp-route-searchTerm="@searchTerm"
                   asp-route-estadoFilter="@estadoFilter" asp-route-estadoPagoFilter="@estadoPagoFilter"
                   asp-route-fechaDesde="@fechaDesde" asp-route-fechaHasta="@fechaHasta" asp-route-pageSize="@pageSize">
                    &laquo;
                </a>
            </li>
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-searchTerm="@searchTerm"
                   asp-route-estadoFilter="@estadoFilter" asp-route-estadoPagoFilter="@estadoPagoFilter"
                   asp-route-fechaDesde="@fechaDesde" asp-route-fechaHasta="@fechaHasta" asp-route-pageSize="@pageSize">
                    &lsaquo;
                </a>
            </li>

            <!-- Paginas -->
            @for (int i = startPage; i <= endPage; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-searchTerm="@searchTerm"
                       asp-route-estadoFilter="@estadoFilter" asp-route-estadoPagoFilter="@estadoPagoFilter"
                       asp-route-fechaDesde="@fechaDesde" asp-route-fechaHasta="@fechaHasta" asp-route-pageSize="@pageSize">@i</a>
                </li>
            }

            <!-- Siguiente y ultima pagina -->
            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-searchTerm="@searchTerm"
                   asp-route-estadoFilter="@estadoFilter" asp-route-estadoPagoFilter="@estadoPagoFilter"
                   asp-route-fechaDesde="@fechaDesde" asp-route-fechaHasta="@fechaHasta" asp-route-pageSize="@pageSize">
                    &rsaquo;
                </a>
            </li>
            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@totalPages" asp-route-searchTerm="@searchTerm"
                   asp-route-estadoFilter="@estadoFilter" asp-route-estadoPagoFilter="@estadoPagoFilter"
                   asp-route-fechaDesde="@fechaDesde" asp-route-fechaHasta="@fechaHasta" asp-route-pageSize="@pageSize">
                    &raquo;
                </a>
            </li>
        </ul>
    </nav>
}

@section Scripts {
    <script>
        // Cambiar cantidad de items por pagina
        document.getElementById('pageSizeSelect').addEventListener('change', function () {
            const pageSize = this.value;
            const searchTerm = '@(ViewBag.SearchTerm ?? "")';
            const estadoFilter = '@(ViewBag.EstadoFilter?.ToString() ?? "")';
            const estadoPagoFilter = '@(ViewBag.EstadoPagoFilter?.ToString() ?? "")';
            const fechaDesde = '@(ViewBag.FechaDesde ?? "")';
            const fechaHasta = '@(ViewBag.FechaHasta ?? "")';

            let url = '@Url.Action("Index")?pageSize=' + pageSize;
            if (searchTerm) url += '&searchTerm=' + encodeURIComponent(searchTerm);
            if (estadoFilter) url += '&estadoFilter=' + encodeURIComponent(estadoFilter);
            if (estadoPagoFilter) url += '&estadoPagoFilter=' + encodeURIComponent(estadoPagoFilter);
            if (fechaDesde) url += '&fechaDesde=' + encodeURIComponent(fechaDesde);
            if (fechaHasta) url += '&fechaHasta=' + encodeURIComponent(fechaHasta);

            window.location.href = url;
        });

        // Establecer el valor correcto del select al cargar
        document.addEventListener('DOMContentLoaded', function () {
            const pageSizeSelect = document.getElementById('pageSizeSelect');
            pageSizeSelect.value = '@ViewBag.PageSize';
        });
    </script>
}
