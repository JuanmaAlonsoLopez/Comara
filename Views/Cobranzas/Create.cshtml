@model comara.Models.Cobro

@{
    ViewData["Title"] = "Create";
}

<h1>Crear</h1>

<h4>Cobranza</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="cliCod" class="control-label"></label>
                <select asp-for="cliCod" class ="form-control" asp-items="ViewBag.cliCod"></select>
            </div>
            <div class="form-group">
                <label asp-for="cobFech" class="control-label"></label>
                <input asp-for="cobFech" class="form-control" />
                <span asp-validation-for="cobFech" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="cobMonto" class="control-label"></label>
                <input asp-for="cobMonto" class="form-control" />
                <span asp-validation-for="cobMonto" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="cobMetodo" class="control-label"></label>
                <input asp-for="cobMetodo" class="form-control" />
                <span asp-validation-for="cobMetodo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Crear" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Volver a la lista</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
