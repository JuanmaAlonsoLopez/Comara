@model comara.Models.Proveedor

@{
    ViewData["Title"] = "Eliminar Proveedor";
}

<h1>Eliminar</h1>

<h3>¿Está seguro que desea eliminar este proveedor?</h3>
<div>
    <h4>Proveedor</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Nombre
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.proNombre)
        </dd>
        <dt class="col-sm-2">
            CUIT
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.proCUIT)
        </dd>
        <dt class="col-sm-2">
            Contacto
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.proContacto)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.proEmail)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.proEmail)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.proCelular)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.proCelular)
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="proCod" />
        <input type="submit" value="Eliminar" class="btn btn-sm btn-danger" />
        <a asp-action="Index" class="btn btn-sm btn-secondary">Volver a la lista</a>
    </form>
</div>
