@model comara.Models.Proveedor

@{
    ViewData["Title"] = "Detalles Proveedor";
}

<h1>Detalles</h1>

<div>
    <h4>Proveedor</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Nombre
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.proNombre)
        </dd>
        <dt class="col-sm-2">
            CUIT
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.proCUIT)
        </dd>
        <dt class="col-sm-2">
            Contacto
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.proContacto)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.proEmail)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.proEmail)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.proCelular)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.proCelular)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.proDescuento)
        </dt>
        <dd class="col-sm-10">
            @if (Model.proDescuento.HasValue)
            {
                @string.Format("{0:N2}%", Model.proDescuento)
            }
            else
            {
                <text>0.00%</text>
            }
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.proCod" class="btn btn-sm btn-warning">Editar</a>
    <a asp-action="Index" class="btn btn-sm btn-secondary">Volver a la lista</a>
</div>
