@model comara.Models.Marca

@{
    ViewData["Title"] = "Crear Marca";
}

<h1>Crear Nueva Marca</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" id="formMarca">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" name="confirmarSimilar" id="confirmarSimilar" value="false" />

            <div class="form-group mb-3">
                <label asp-for="marNombre" class="control-label">Nombre</label>
                <input asp-for="marNombre" class="form-control" id="marNombre" />
                <span asp-validation-for="marNombre" class="text-danger"></span>
                <span id="nombreError" class="text-danger" style="display:none;"></span>
                <div id="nombreWarning" class="alert alert-warning mt-2" style="display:none;">
                    <strong>Marcas similares encontradas:</strong>
                    <ul id="listaSimilares"></ul>
                </div>
            </div>

            @if (ViewBag.MostrarConfirmacion == true && ViewBag.MarcasSimilares != null)
            {
                <div class="alert alert-warning">
                    <strong>Se encontraron marcas con nombres similares:</strong>
                    <ul>
                        @foreach (var similar in (List<string>)ViewBag.MarcasSimilares)
                        {
                            <li>@similar</li>
                        }
                    </ul>
                    <p>Si desea continuar de todas formas, haga clic en "Confirmar y Crear".</p>
                    <button type="submit" class="btn btn-warning btn-sm" onclick="$('#confirmarSimilar').val('true');">
                        Confirmar y Crear
                    </button>
                </div>
            }

            <hr />
            <div class="form-group">
                <input type="submit" value="Crear" class="btn btn-sm btn-success" id="btnCrear" />
                <a asp-action="Index" class="btn btn-sm btn-secondary">Volver a la Lista</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function() {
            var nombreTimeout;
            var haySimilares = false;

            $('#marNombre').on('input', function() {
                clearTimeout(nombreTimeout);
                var nombre = $(this).val();
                var $error = $('#nombreError');
                var $warning = $('#nombreWarning');
                var $input = $(this);
                var $listaSimilares = $('#listaSimilares');

                if (!nombre || nombre.trim() === '') {
                    $error.hide();
                    $warning.hide();
                    $input.removeClass('is-invalid is-warning');
                    haySimilares = false;
                    return;
                }

                nombreTimeout = setTimeout(function() {
                    $.get('@Url.Action("VerificarNombre", "Marcas")', { nombre: nombre }, function(data) {
                        if (data.existe) {
                            $error.text('Ya existe una marca con este nombre.').show();
                            $warning.hide();
                            $input.addClass('is-invalid');
                            haySimilares = false;
                        } else if (data.similares && data.similares.length > 0) {
                            $error.hide();
                            $listaSimilares.empty();
                            data.similares.forEach(function(s) {
                                $listaSimilares.append('<li>' + s + '</li>');
                            });
                            $warning.show();
                            $input.removeClass('is-invalid').addClass('is-warning');
                            haySimilares = true;
                        } else {
                            $error.hide();
                            $warning.hide();
                            $input.removeClass('is-invalid is-warning');
                            haySimilares = false;
                        }
                    });
                }, 500);
            });

            // Interceptar el submit para confirmar si hay similares
            $('#formMarca').on('submit', function(e) {
                if (haySimilares && $('#confirmarSimilar').val() !== 'true') {
                    e.preventDefault();
                    if (confirm('Se encontraron marcas con nombres similares. ¿Desea continuar de todas formas?')) {
                        $('#confirmarSimilar').val('true');
                        $(this).submit();
                    }
                }
            });
        });
    </script>
    <style>
        .is-warning {
            border-color: #ffc107 !important;
            box-shadow: 0 0 0 0.2rem rgba(255, 193, 7, 0.25) !important;
        }
    </style>
}
