@model comara.Models.Marca

@{
    ViewData["Title"] = "Detalles de Marca";
}

<h1>Detalles de Marca</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Código
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.marCod)
        </dd>
        <dt class="col-sm-2">
            Nombre
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.marNombre)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.marCod" class="btn btn-sm btn-warning">Editar</a>
    <a asp-action="Index" class="btn btn-sm btn-secondary">Volver a la Lista</a>
</div>
