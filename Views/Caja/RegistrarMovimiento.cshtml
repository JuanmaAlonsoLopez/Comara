@model comara.Models.ViewModels.MovimientoCajaViewModel

@{
    ViewData["Title"] = "Registrar Movimiento de Caja";
}

<div class="container">
    <h2>Registrar Movimiento de Caja</h2>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <form asp-action="RegistrarMovimiento" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="card mb-3">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Datos del Movimiento</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="MovFecha" class="control-label"></label>
                                    <input asp-for="MovFecha" class="form-control" type="date" />
                                    <span asp-validation-for="MovFecha" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="MovMonto" class="control-label"></label>
                                    <input asp-for="MovMonto" class="form-control" type="number" step="0.01" />
                                    <span asp-validation-for="MovMonto" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="MovTipo" class="control-label"></label>
                                    <select asp-for="MovTipo" class="form-select" asp-items="ViewBag.MovTipo" id="tipoMovimientoSelect">
                                        <option value="">-- Seleccione tipo de movimiento --</option>
                                    </select>
                                    <span asp-validation-for="MovTipo" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="MovMetodoPago" class="control-label"></label>
                                    <select asp-for="MovMetodoPago" class="form-select" asp-items="ViewBag.MovMetodoPago" id="metodoPagoSelect">
                                        <option value="">-- Seleccione método de pago --</option>
                                    </select>
                                    <span asp-validation-for="MovMetodoPago" class="text-danger"></span>
                                    <small class="form-text text-muted">Solo Efectivo o Cheque</small>
                                </div>
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="MovDescripcion" class="control-label"></label>
                            <textarea asp-for="MovDescripcion" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="MovDescripcion" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3" id="selectorCheque" style="display: none;">
                            <label asp-for="ChqCod" class="control-label">Seleccionar Cheque</label>
                            <select asp-for="ChqCod" class="form-select" asp-items="ViewBag.ChqCod">
                                <option value="">-- Ninguno (solo para egresos de cheques) --</option>
                            </select>
                            <span asp-validation-for="ChqCod" class="text-danger"></span>
                            <small class="form-text text-muted">
                                Seleccione el cheque que sale de caja (solo para egresos)
                            </small>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-success">Registrar Movimiento</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>

        <div class="col-md-4">
            <div class="card bg-light">
                <div class="card-header">
                    <h5 class="mb-0">Información</h5>
                </div>
                <div class="card-body">
                    <h6>Tipos de Movimientos:</h6>
                    <ul>
                        <li><strong>INGRESO:</strong> Dinero que entra a caja</li>
                        <li><strong>EGRESO:</strong> Dinero que sale de caja</li>
                    </ul>
                    <hr />
                    <h6>Ejemplos de Movimientos:</h6>
                    <p class="small"><strong>Ingresos:</strong></p>
                    <ul class="small">
                        <li>Venta en efectivo</li>
                        <li>Depositar dinero inicial</li>
                        <li>Recepción de cheque</li>
                    </ul>
                    <p class="small"><strong>Egresos:</strong></p>
                    <ul class="small">
                        <li>Pago a proveedor</li>
                        <li>Gastos operativos</li>
                        <li>Retiro personal</li>
                        <li>Depositar cheque en banco</li>
                        <li>Entregar cheque a tercero</li>
                    </ul>
                </div>
            </div>

            <div class="card bg-light mt-3">
                <div class="card-header">
                    <h5 class="mb-0">Cheques en Caja</h5>
                </div>
                <div class="card-body">
                    <p class="small text-muted">
                        Los cheques que están físicamente en caja pueden ser egresados
                        (depositados en banco, entregados a proveedor, etc.). Al seleccionar
                        un cheque en un egreso, este será marcado automáticamente como
                        fuera de caja.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function () {
            function actualizarSelectorCheque() {
                var tipoMovimiento = $('#tipoMovimientoSelect option:selected').text();
                var metodoPago = $('#metodoPagoSelect option:selected').text();

                // Mostrar selector de cheque solo si es EGRESO y método Cheque
                if (tipoMovimiento.includes('EGRESO') && metodoPago.includes('Cheque')) {
                    $('#selectorCheque').slideDown();
                } else {
                    $('#selectorCheque').slideUp();
                    $('#ChqCod').val('');
                }
            }

            $('#tipoMovimientoSelect, #metodoPagoSelect').on('change', function () {
                actualizarSelectorCheque();
            });

            // Verificar al cargar la página
            actualizarSelectorCheque();
        });
    </script>
}
