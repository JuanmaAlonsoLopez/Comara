@model IEnumerable<comara.Models.Articulo>

@{
    ViewData["Title"] = "Artículos";
}

<h1>Artículos</h1>

<p>
    <a asp-action="Create" class="btn btn-sm btn-primary">Crear Nuevo</a>
    <button type="button" class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#importModal">
        Importar desde Excel
    </button>
    <a asp-action="DownloadTemplate" class="btn btn-sm btn-info">
        <i class="bi bi-download"></i> Descargar Plantilla Excel
    </a>
</p>

<!-- Buscador -->
<form method="get" asp-action="Index" class="mb-3">
    <div class="input-group">
        <input type="text" name="searchTerm" class="form-control"
               value="@ViewBag.SearchTerm"
               placeholder="Buscar por Id, descripción, marca o proveedor..." />
        <button type="submit" class="btn btn-outline-primary">Buscar</button>
        @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
        }
    </div>
    <input type="hidden" name="pageSize" value="@ViewBag.PageSize" />
</form>

<!-- Info de resultados -->
<div class="d-flex justify-content-between align-items-center mb-2">
    <small class="text-muted">
        @if (ViewBag.TotalItems > 0)
        {
            <span>Mostrando @((ViewBag.CurrentPage - 1) * ViewBag.PageSize + 1)-@Math.Min(ViewBag.CurrentPage * ViewBag.PageSize, ViewBag.TotalItems) de @ViewBag.TotalItems artículos</span>
        }
        else
        {
            <span>No se encontraron artículos</span>
        }
        @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
        {
            <span> (filtrado por: "@ViewBag.SearchTerm")</span>
        }
    </small>
    <div>
        <label class="me-2">Por página:</label>
        <select id="pageSizeSelect" class="form-select form-select-sm d-inline-block" style="width: auto;">
            <option value="20">20</option>
            <option value="50">50</option>
            <option value="100">100</option>
        </select>
    </div>
</div>

@if (TempData["ImportMessage"] != null)
{
    var importMessage = TempData["ImportMessage"]?.ToString() ?? "";
    // Sanitizar: solo permitir saltos de linea convertidos a <br>
    var sanitizedMessage = System.Net.WebUtility.HtmlEncode(importMessage).Replace("&#10;", "<br/>").Replace("\n", "<br/>");
    <div class="alert alert-@(TempData["ImportSuccess"] != null && (bool)TempData["ImportSuccess"] ? "success" : "danger") alert-dismissible fade show" role="alert">
        @Html.Raw(sanitizedMessage)
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ImportWarnings"] != null)
{
    var importWarnings = TempData["ImportWarnings"]?.ToString() ?? "";
    // Sanitizar: solo permitir saltos de linea convertidos a <br>
    var sanitizedWarnings = System.Net.WebUtility.HtmlEncode(importWarnings).Replace("&#10;", "<br/>").Replace("\n", "<br/>");
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <strong>Advertencias:</strong><br/>
        @Html.Raw(sanitizedWarnings)
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["WarningMessage"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <strong>⚠️</strong> @TempData["WarningMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Modal para importar Excel -->
<div class="modal fade" id="importModal" tabindex="-1" aria-labelledby="importModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="importModalLabel">Importar Artículos desde Excel</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="ImportExcel" method="post" enctype="multipart/form-data">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="excelFile" class="form-label">Seleccionar archivo Excel (.xlsx)</label>
                        <input type="file" class="form-control" id="excelFile" name="excelFile" accept=".xlsx" required>
                    </div>
                    <div class="alert alert-info">
                        <strong>Formato del archivo:</strong>
                        <ul class="mb-0">
                            <li>El archivo debe ser .xlsx (Excel)</li>
                            <li>La primera fila debe contener los encabezados</li>
                            <li>Descargue la plantilla para ver el formato correcto</li>
                        </ul>
                    </div>
                    <div class="alert alert-success">
                        <strong>Códigos de IVA:</strong>
                        <table class="table table-sm table-bordered mt-2 mb-0" style="background-color: white;">
                            <thead>
                                <tr>
                                    <th>Código</th>
                                    <th>Porcentaje</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>3</td>
                                    <td>0.00%</td>
                                </tr>
                                <tr>
                                    <td>4</td>
                                    <td>10.50%</td>
                                </tr>
                                <tr>
                                    <td>5</td>
                                    <td>21.00%</td>
                                </tr>
                                <tr>
                                    <td>6</td>
                                    <td>27.00%</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Importar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-hover" style="width: 100%; min-width: 1100px;">
        <thead>
            <tr>
                <th>Id</th>
                <th>Descripción</th>
                <th>Marca</th>
                <th>Costo Neto</th>
                <th>Costo c/Desc</th>
                <th>Costo Final</th>
                <th>Stock</th>
                <th style="width: 250px;">Acciones</th>
            </tr>
        </thead>
        <tbody id="articulosTableBody">
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.ArtDesc</td>
                    <td>@(item.Marca?.marNombre ?? "-")</td>
                    <td>@string.Format("${0:N2}", item.ArtCost ?? 0)</td>
                    <td>
                        @string.Format("${0:N2}", item.CostoConDescuento)
                        @if (item.Proveedor?.proDescuento > 0)
                        {
                            <small class="text-success">(-@string.Format("{0:N2}", item.Proveedor.proDescuento)%)</small>
                        }
                    </td>
                    <td>
                        @string.Format("${0:N2}", item.CostoFinal)
                        @if (item.Iva?.Porcentaje > 0)
                        {
                            <small class="text-info">(+@string.Format("{0:N2}", item.Iva.Porcentaje)% IVA)</small>
                        }
                    </td>
                    <td>
                        @if (item.ArtStock.HasValue)
                        {
                            @(item.ArtStock == Math.Truncate(item.ArtStock.Value) ? item.ArtStock.Value.ToString("N0") : item.ArtStock.Value.ToString("N2"))
                        }
                    </td>
                    <td class="text-nowrap">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a> |
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Detalles</a> |
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Paginación -->
@if (ViewBag.TotalPages > 1)
{
    <nav aria-label="Paginación de artículos" class="mt-3">
        <ul class="pagination justify-content-center">
            @{
                int currentPage = ViewBag.CurrentPage;
                int totalPages = ViewBag.TotalPages;
                string searchTerm = ViewBag.SearchTerm ?? "";
                int pageSize = ViewBag.PageSize;

                // Determinar rango de páginas a mostrar
                int startPage = Math.Max(1, currentPage - 2);
                int endPage = Math.Min(totalPages, currentPage + 2);

                // Ajustar para mostrar siempre 5 páginas si es posible
                if (endPage - startPage < 4)
                {
                    if (startPage == 1)
                        endPage = Math.Min(totalPages, startPage + 4);
                    else if (endPage == totalPages)
                        startPage = Math.Max(1, endPage - 4);
                }
            }

            <!-- Primera página y anterior -->
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="1" asp-route-searchTerm="@searchTerm" asp-route-pageSize="@pageSize">
                    &laquo;
                </a>
            </li>
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-searchTerm="@searchTerm" asp-route-pageSize="@pageSize">
                    &lsaquo;
                </a>
            </li>

            <!-- Páginas -->
            @for (int i = startPage; i <= endPage; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-searchTerm="@searchTerm" asp-route-pageSize="@pageSize">@i</a>
                </li>
            }

            <!-- Siguiente y última página -->
            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-searchTerm="@searchTerm" asp-route-pageSize="@pageSize">
                    &rsaquo;
                </a>
            </li>
            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@totalPages" asp-route-searchTerm="@searchTerm" asp-route-pageSize="@pageSize">
                    &raquo;
                </a>
            </li>
        </ul>
    </nav>
}

@section Scripts {
    <script>
        // Cambiar cantidad de items por página
        document.getElementById('pageSizeSelect').addEventListener('change', function() {
            const pageSize = this.value;
            const searchTerm = '@ViewBag.SearchTerm' || '';
            let url = '@Url.Action("Index")?pageSize=' + pageSize;
            if (searchTerm) {
                url += '&searchTerm=' + encodeURIComponent(searchTerm);
            }
            window.location.href = url;
        });

        // Establecer el valor correcto del select al cargar
        document.addEventListener('DOMContentLoaded', function() {
            const pageSizeSelect = document.getElementById('pageSizeSelect');
            pageSizeSelect.value = '@ViewBag.PageSize';
        });
    </script>
}
